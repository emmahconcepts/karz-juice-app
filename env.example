# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/karzjuice
APP_URL=https://karzjuice.app
NODE_ENV=production
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
OWNER_OPEN_ID=your-oauth-owner-id

# ── MTN Mobile Money ──────────────────────────────────────────────────────────
MTN_ENV=sandbox
MTN_API_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_API_KEY=your-mtn-api-key
MTN_API_SECRET=your-mtn-api-secret
MTN_COLLECTION_PRIMARY_KEY=your-collection-key
MTN_MERCHANT_ID=your-merchant-id

# ── PesaPal ───────────────────────────────────────────────────────────────────
PESAPAL_CONSUMER_KEY=your-pesapal-key
PESAPAL_CONSUMER_SECRET=your-pesapal-secret
PESAPAL_WEBHOOK_SECRET=your-webhook-secret
PESAPAL_SANDBOX=true
PESAPAL_API_URL=https://api.pesapal.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@karzjuice.app
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=notifications@karzjuice.app
SMTP_FROM_NAME=Karz Juice

# ── E-Commerce ────────────────────────────────────────────────────────────────
WHATSAPP_NUMBER=256700000000
